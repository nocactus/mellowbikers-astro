---
import Default from "../layouts/Default.astro";
import MountainSeparator from "../components/MountainSeparator.astro";
import Footer from "../components/Footer.astro";
import { getEntry, getCollection } from 'astro:content';

const pageSettings = await getEntry('page-settings', 'spotlight');
const members = (await getCollection('members')).sort((a, b) => a.data.order - b.data.order);

const membersWithContent = await Promise.all(
  members.map(async (member) => {
    const { Content } = await member.render();
    return { ...member, Content };
  })
);
---
<Default title={pageSettings.data.seo.title} description={pageSettings.data.seo.description}>

  <main class="w-full bg-mellow-dark">

    <!-- Hero Section -->
    <section
      class="relative w-full min-h-[90vh] flex items-end justify-center bg-cover bg-center bg-fixed bg-mellow-dark px-4 pb-24"
      style={`background-image: url('${pageSettings.data.hero.backgroundImage}'); background-position: ${pageSettings.data.hero.backgroundPosition ?? '50% 50%'};`}
    >
      <MountainSeparator position="bottom" color="mellow-red" />

      <div class="relative z-10 text-center pb-8">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-mellow-white mt-0 mb-4" style="letter-spacing: -0.05em; text-shadow: 10px 10px 30px rgba(0, 0, 0, 0.2);">
          {pageSettings.data.hero.title}
        </h1>
        <div class="flex justify-center">
          <svg class="w-8 h-8 text-mellow-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>
      </div>
    </section>

    <!-- Lead Text Section -->
    <section class="relative w-full bg-mellow-red px-4 py-12 lg:py-16">
      <MountainSeparator position="top" color="mellow-red" />

      <div class="relative z-10 max-w-7xl mx-auto grid md:grid-cols-2 gap-8 md:gap-4">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-mellow-groen mb-4">
            In the spotlight
          </h2>
          <p class="text-xl md:text-2xl text-mellow-white leading-relaxed">
            Af en toe zetten we een van de Mellows in de spotlight. Zo leer je ze een klein beetje kennen (niet schrikken, het zijn net echte mensen)… Onthullend. Schokkend. Met epische verhalen, zoals altijd. 😎<br/><br/>
            Ook lid worden van onze toffe club? <a href="/lid-worden" class="text-mellow-groen hover:text-mellow-groen/80 underline">Hier kan dat</a>.
          </p>
        </div>
        <div class="flex items-right md:justify-end">
          <p class="text-xl md:text-2xl text-mellow-white leading-relaxed">
            {membersWithContent.map((member) => (
              <span>🚵🏻‍♂️ <a href={`#${member.data.memberId}`} class="text-mellow-white hover:text-mellow-groen">{member.data.name}</a><br/></span>
            ))}
          </p>
        </div>
      </div>
    </section>

    <!-- Member Sections -->
    {membersWithContent.map((member) => (
      <section id={member.data.memberId} class="w-full bg-mellow-dark px-4 py-16 lg:py-24">
        <div class="max-w-5xl mx-auto">
          <div class={`grid ${member.data.images.length > 2 ? 'grid-cols-2 md:grid-cols-3' : 'grid-cols-2'} gap-4 mb-8`}>
            {member.data.images.map((img) => (
              <img src={img.src} alt={img.alt} class="w-full h-64 object-cover rounded" loading="lazy" />
            ))}
          </div>
          <h3 class="text-2xl md:text-3xl font-bold text-mellow-groen mb-6">{member.data.name}</h3>
          <div class="text-base md:text-lg text-mellow-white leading-relaxed space-y-4">
            <member.Content />
          </div>
          <hr class="border-t-2 border-mellow-red my-12" />
        </div>
      </section>
    ))}

    <Footer
      backgroundImage={pageSettings.data.footer.backgroundImage}
      backgroundPosition={pageSettings.data.footer.backgroundPosition}
    />

  </main>
</Default>
