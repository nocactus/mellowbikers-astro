---
export const prerender = false;

let error = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const password = formData.get('password') as string;
  const redirectTo = Astro.url.searchParams.get('redirect') || '/keystatic';

  const envPassword = (Astro.locals.runtime?.env?.KEYSTATIC_PASSWORD as string)
    || import.meta.env.KEYSTATIC_PASSWORD
    || '';

  if (password && password === envPassword) {
    const token = btoa(`keystatic-admin:${envPassword}`);
    Astro.cookies.set('keystatic_session', token, {
      httpOnly: true,
      secure: true,
      sameSite: 'lax',
      maxAge: 60 * 60 * 24 * 7, // 1 week
      path: '/',
    });
    return Astro.redirect(redirectTo);
  }

  error = true;
}
---
<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Admin Login — Mellowbikers</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #0d0f19;
      font-family: 'Inter', system-ui, sans-serif;
      color: #f1ffff;
    }
    .login-card {
      width: 100%;
      max-width: 380px;
      padding: 2.5rem;
      border-radius: 0.75rem;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    h1 {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 0.25rem;
      color: #2affcc;
    }
    p {
      font-size: 0.875rem;
      color: rgba(241, 255, 255, 0.6);
      margin-bottom: 1.5rem;
    }
    label {
      display: block;
      font-size: 0.875rem;
      margin-bottom: 0.375rem;
    }
    input[type="password"] {
      width: 100%;
      padding: 0.625rem 0.875rem;
      border-radius: 0.375rem;
      border: 1px solid #2affcc;
      background: #0d0f19;
      color: #f1ffff;
      font-size: 1rem;
      outline: none;
      transition: border-color 0.15s;
    }
    input[type="password"]:focus {
      border-color: #004fff;
      box-shadow: 0 0 0 2px rgba(0, 79, 255, 0.25);
    }
    .error {
      color: #d90b1e;
      font-size: 0.875rem;
      margin-top: 0.5rem;
    }
    button {
      width: 100%;
      margin-top: 1.25rem;
      padding: 0.625rem;
      border-radius: 0.5rem;
      border: 2px solid #004fff;
      background: #004fff;
      color: #f1ffff;
      font-size: 0.9375rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
    }
    button:hover {
      background: rgba(0, 79, 255, 0.8);
      border-color: rgba(0, 79, 255, 0.5);
    }
  </style>
</head>
<body>
  <div class="login-card">
    <h1>Keystatic Admin</h1>
    <p>Log in om content te beheren.</p>
    <form method="POST">
      <label for="password">Wachtwoord</label>
      <input
        type="password"
        id="password"
        name="password"
        required
        autofocus
        autocomplete="current-password"
      />
      {error && <div class="error">Onjuist wachtwoord. Probeer het opnieuw.</div>}
      <button type="submit">Inloggen</button>
    </form>
  </div>
</body>
</html>
