---
import Default from "../layouts/Default.astro";
import MountainSeparator from "../components/MountainSeparator.astro";
import Footer from "../components/Footer.astro";
import { getEntry, getCollection } from 'astro:content';

// Haal page settings op
const pageSettings = await getEntry('page-settings', 'agenda');

// Haal settings op
const settings = await getEntry('agenda-settings', 'settings');
const { introText, leadText } = settings.data;

// Haal alle agenda items op en sorteer ze
const allAgendaItems = await getCollection('agenda-items');
const agendaItems = allAgendaItems
  .sort((a, b) => a.data.order - b.data.order)
  .map(item => ({
    date: item.data.date,
    title: item.data.title,
    description: item.body,
    completed: item.data.completed,
  }));
---
<Default title={pageSettings.data.seo.title} description={pageSettings.data.seo.description}>

  <main>
    <!-- Hero Section -->
    <section
      class="relative w-full min-h-[90vh] bg-mellow-dark bg-cover bg-center bg-fixed flex items-end pb-20 px-4"
      style={`background-image: url('${pageSettings.data.hero.backgroundImage}'); background-position: ${pageSettings.data.hero.backgroundPosition ?? '50% 50%'};`}
    >
      <MountainSeparator position="bottom" color="mellow-red" />

      <div class="relative z-10 w-full text-center">
        <h2 class="text-6xl font-bold text-mellow-white mb-6" style="text-shadow: 10px 10px 30px rgba(0,0,0,0.2); line-height: 1; letter-spacing: -0.05em;">
          {pageSettings.data.hero.title}
        </h2>
        <h2 class="text-2xl text-mellow-white max-w-4xl mx-auto mb-8" style="text-shadow: 2px 2px 2px rgba(0,0,0,0.2);">
          {introText}
        </h2>
        <div class="text-mellow-white text-4xl">
          <svg class="w-8 h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>
      </div>
    </section>

    <!-- Agenda Content Section -->
    <section class="relative w-full bg-mellow-red py-12 md:py-20 px-4">
      <MountainSeparator position="top" color="mellow-red" />

      <div class="relative z-10 max-w-7xl mx-auto">
        <div class="bg-mellow-dark rounded-lg p-6 md:p-12">
          <h4 class="text-lg md:text-xl text-mellow-groen font-bold mb-4">Agenda clubritten & weekenden</h4>
          <p class="text-base text-mellow-white mb-8">
            {leadText}
          </p>

          <ul class="space-y-4 text-mellow-white mb-8">
            {agendaItems.map(item => (
              <li class="flex gap-3">
                <svg class="w-5 h-5 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  {item.completed ? (
                    <>
                      <path d="M9 11l3 3L22 4 20.59 2.59 12 11.17 8.41 7.59 7 9z"/>
                      <rect x="3" y="3" width="18" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="2"/>
                    </>
                  ) : (
                    <rect x="3" y="3" width="18" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="2"/>
                  )}
                </svg>
                <span>
                  <strong>{item.date}: {item.title}</strong><br/>
                  {item.description}
                </span>
              </li>
            ))}
          </ul>

          <div class="mt-8">
            <a href="/lid-worden" class="inline-block px-6 py-3 rounded-lg bg-mellow-blue hover:bg-mellow-blue/80 text-mellow-white font-medium transition-colors border-2 border-mellow-blue hover:border-mellow-blue/50">
              Ook meerijden? Word lid!
            </a>
          </div>

          <p class="text-sm text-mellow-white text-center mt-8">
            Nog geen zin om lid te worden? Benieuwd of wij wel bij jou passen? Je kunt gewoon een keer meerijden! <a href="/#socials" class="underline text-mellow-groen hover:text-mellow-groen/80">Laat het ons hier even weten</a>.
          </p>
        </div>
      </div>
    </section>

    <Footer
      backgroundImage={pageSettings.data.footer.backgroundImage}
      backgroundPosition={pageSettings.data.footer.backgroundPosition}
    />

  </main>
</Default>
