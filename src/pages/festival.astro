---
import Default from "../layouts/Default.astro";
import { getEntry } from 'astro:content';

const festival = await getEntry('festival', 'festival-2025');

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SportsEvent",
  "name": `${festival.data.title} ${festival.data.year}`,
  "description": festival.data.description.replace(/<[^>]+>/g, ''),
  "startDate": "2025-06-20",
  "endDate": "2025-06-22",
  "location": {
    "@type": "Place",
    "name": festival.data.location,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Essen",
      "addressCountry": "BE"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Mellowbikers",
    "url": "https://mellowbikers.nl"
  }
};
---
<Default
  title={festival.data.seo.title}
  description={festival.data.seo.description}
  jsonLd={jsonLd}
>

  <main class="w-full bg-mellow-dark bg-contain bg-repeat" style="background-image: url('https://mellowbikers.nl/wp-content/uploads/2024/12/bg-tracks.png');">

    <!-- Header Section -->
    <section class="max-w-[800px] mx-auto px-4 py-12">
      <div class="text-center">
        <img src="/assets/uploads/mellowbikers-logo-2023-400-203x300.png" alt="Mellowbikers" class="w-24 md:w-32 mx-auto mb-4" />

        <p class="text-xs md:text-sm text-gray-400 uppercase tracking-widest mb-2">
          Presenteert
        </p>

        <h2 class="text-3xl md:text-4xl lg:text-5xl text-mellow-white mb-2 font-['Notable']" style="background: linear-gradient(90deg, rgb(42,255,204) 0%, #f1ffff 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
          {festival.data.title} <span class="text-mellow-groen">{festival.data.year}</span>
        </h2>

        <p class="text-lg md:text-xl text-gray-400 uppercase tracking-widest mb-8">
          {festival.data.dates} ✌️ {festival.data.location}
        </p>

        <p class="text-base md:text-lg text-gray-400 leading-relaxed" set:html={festival.data.description} />
      </div>
    </section>

    <!-- Image Gallery Carousel -->
    <section class="w-full overflow-hidden mb-12">
      <div class="flex gap-4 animate-scroll">
        <img src="https://mellowbikers.nl/wp-content/uploads/2024/12/camping.jpg" alt="Camping" class="h-64 w-64 object-cover rounded aspect-square" />
        <img src="https://mellowbikers.nl/wp-content/uploads/2024/12/PHOTO-2023-05-05-11-47-53.jpg" alt="Festival 1" class="h-64 w-64 object-cover rounded aspect-square" />
        <img src="https://mellowbikers.nl/wp-content/uploads/2024/12/PHOTO-2023-05-05-14-57-30.jpg" alt="Festival 2" class="h-64 w-64 object-cover rounded aspect-square" />
        <img src="https://mellowbikers.nl/wp-content/uploads/2024/12/PHOTO-2023-05-05-14-57-31.jpg" alt="Festival 3" class="h-64 w-64 object-cover rounded aspect-square" />
      </div>
    </section>

    <!-- Pricing Cards -->
    <section class="max-w-6xl mx-auto px-4 mb-16">
      <div class="grid md:grid-cols-3 gap-6">
        {festival.data.tickets.map((ticket) => (
          <a href={ticket.link} target="_blank" class="bg-mellow-white rounded-lg p-6 border-[9px] border-mellow-groen hover:border-mellow-groen/70 transition-colors text-center">
            <div class="text-5xl mb-4">{ticket.emoji}</div>
            <h2 class="text-xl font-bold mb-2 text-mellow-dark">{ticket.title} {ticket.price}</h2>
            <p class="text-mellow-dark">{ticket.description}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Main Content -->
    <section class="max-w-[800px] mx-auto px-4 mb-16">
      <p class="text-base md:text-lg text-mellow-white mb-8 leading-relaxed">
        Ook een keer zo'n episch Mellow-campingweekend willen meemaken? Op het Mellow Bike Festival beleef je superveel MTB-fun: doe met een team mee met de 6-uursrace op een technisch MTB-parcours, verken de Brabantse Wal met schitterende tochten met gids, live muziek, All-You-Can-Eat-Foodtruck, lokaal bier van Brouwerij Sterck en natuurlijk een gezellige campingovernachting! Feestje gegarandeerd✌️🔥
      </p>

      <h3 class="text-base md:text-lg text-mellow-white uppercase font-bold mb-4 mt-8">Campingweekend</h3>
      <p class="text-mellow-white mb-8 leading-relaxed">
        De inschrijving bedraagt €87 per persoon en is inclusief twee nachten camping op de Rommeshoef, heerlijk eten bij onze foodtruck en live muziek van de Daltons Unleashed 🤘 Tijdens de inschrijving kun je zelf een team van 2, 3 of 4 personen aanmelden voor de 6-uursrace. Ook individuele deelname is mogelijk. Liefst in een team meerijden maar alleen? Dan delen wij je in bij een team.
      </p>

      <h3 class="text-base md:text-lg text-mellow-white uppercase font-bold mb-4 mt-8">Dagtickets</h3>
      <p class="text-mellow-white mb-8 leading-relaxed">
        We hebben ook dagtickets voor <strong>slechts €57, inclusief race, All-You-Can-Eat-Foodtruck en afterparty!</strong> Geen zin in de 6-uursrace? Dan rij je gewoon mee met een van onze gave GPX-tochten met of zonder gids over de Brabantse Wal. We kennen de mooiste trails en zorgen dat je onze MTB-achtertuin leert kennen. Er is veel te ontdekken in deze regio! Natuurlijk zijn er verschillende afstanden om te rijden, voor beginners, gevorderden of <em>'kijk maar hoe ver we komen want gisteren was het een beetje te gezellig in de bar'</em>...alles kan 😁
      </p>

      <p class="text-mellow-white text-center uppercase mb-6">
        Rij je mee? Claim hier je spot op camping en zorg dat je erbij bent!
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
        {festival.data.tickets.filter(t => t.title === 'Campingweekend' || t.title === '1-dag ticket').map((ticket) => (
          <a href={ticket.link} target="_blank" class="px-6 py-3 bg-mellow-groen hover:bg-mellow-groen/80 text-mellow-dark font-bold rounded-lg border-2 border-mellow-groen hover:border-mellow-white transition-colors text-center">
            Inschrijven {ticket.title} {ticket.price}
          </a>
        ))}
      </div>

      <p class="text-mellow-white text-center italic mb-8">
        Nog niet zeker of je kunt? Nog aan het sparen voor een nieuwe MTB? Laat je e-mailadres achter en we sturen je updates over het Mellow Bike Festival.
      </p>

      <div class="text-center mb-8">
        <button class="px-8 py-3 text-mellow-white border-2 border-mellow-white rounded-lg hover:bg-mellow-white hover:text-mellow-dark transition-colors">
          Hou me op de hoogte
        </button>
      </div>

      <!-- Program -->
      <h2 class="text-xl md:text-2xl text-mellow-white font-bold mb-6 mt-12 font-['Notable']">
        Voorlopig programma:
      </h2>

      <ul class="space-y-4 text-mellow-white mb-12">
        {festival.data.program.map((item) => (
          <li class="flex gap-3">
            <span class="text-mellow-groen text-xl">{item.emoji}</span>
            <span set:html={item.text} />
          </li>
        ))}
      </ul>
    </section>

    <!-- Navigation Tiles -->
    <section class="max-w-6xl mx-auto px-4 mb-16" id="tiles">
      <p class="text-mellow-white text-center mb-6">
        Bekijk hier meer over het <em>Mellow Bike Festival.</em>
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <a href="#camping" class="relative overflow-hidden rounded group">
          <img src="https://mellowbikers.nl/wp-content/uploads/2024/12/camping-1.jpg" alt="Camping" class="w-full h-64 object-cover" />
          <div class="absolute bottom-0 left-0 right-0 bg-mellow-dark bg-opacity-80 p-4 text-center">
            <span class="text-mellow-white uppercase tracking-wider font-bold">Camping</span>
          </div>
        </a>

        <a href="#race" class="relative overflow-hidden rounded group">
          <img src="https://mellowbikers.nl/wp-content/uploads/2024/12/6-uur.jpg" alt="6-uursrace" class="w-full h-64 object-cover" />
          <div class="absolute bottom-0 left-0 right-0 bg-mellow-dark bg-opacity-80 p-4 text-center">
            <span class="text-mellow-white uppercase tracking-wider font-bold">6-uursrace</span>
          </div>
        </a>

        <a href="#muziek" class="relative overflow-hidden rounded group">
          <img src="https://mellowbikers.nl/wp-content/uploads/2025/01/daltons-unleashed-1.jpeg" alt="Live Muziek" class="w-full h-64 object-cover" />
          <div class="absolute bottom-0 left-0 right-0 bg-mellow-dark bg-opacity-80 p-4 text-center">
            <span class="text-mellow-white uppercase tracking-wider font-bold">Live Muziek</span>
          </div>
        </a>
      </div>
    </section>

    <!-- Dynamic Sections (Camping, Race, Muziek) -->
    {festival.data.sections.map((section) => (
      <section class="max-w-[800px] mx-auto px-4 mb-16" id={section.id}>
        <h3 class="text-lg md:text-xl text-mellow-white mb-6 font-['Notable']" set:html={section.title} />

        <div set:html={section.body} />

        {section.id === 'camping' && (
          <>
            <div class="mb-6">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2478.123456789!2d4.4637!3d51.4637!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNTHCsDI3JzQ5LjMiTiA0wrAyNyc0OS4zIkU!5e0!3m2!1sen!2snl!4v1234567890"
                width="100%"
                height="300"
                style="border:0; filter: grayscale(100%);"
                allowfullscreen=""
                loading="lazy"
              ></iframe>
            </div>
            <div class="text-right mb-6">
              <a href="#tiles" class="text-mellow-groen text-3xl hover:text-mellow-groen/80">↗</a>
            </div>
            <div class="text-center">
              <a href={festival.data.tickets[0].link} target="_blank" class="inline-block px-6 py-3 bg-mellow-groen hover:bg-mellow-groen/80 text-mellow-dark font-bold rounded-lg border-2 border-mellow-groen hover:border-mellow-white transition-colors">
                📋 Inschrijven Festival
              </a>
            </div>
          </>
        )}

        {section.id !== 'camping' && (
          <div class="text-right">
            <a href="#tiles" class="text-mellow-groen text-3xl hover:text-mellow-groen/80">↗</a>
          </div>
        )}
      </section>
    ))}

    <!-- Sponsors Section -->
    <section class="max-w-6xl mx-auto px-4 py-16 mb-16">
      <p class="text-mellow-white text-opacity-50 text-center text-sm mb-8">
        Dit evenement was niet mogelijk geweest zonder deze sponsors, samenwerkingen & partners:
      </p>

      <div class="flex flex-wrap justify-around items-center gap-8">
        {festival.data.sponsors.map((sponsor) => (
          <a href={sponsor.link} target="_blank" class="grayscale hover:grayscale-0 transition-all">
            <img src={sponsor.logo} alt={sponsor.name} class="h-16 md:h-20" />
          </a>
        ))}
      </div>
    </section>

  </main>
</Default>
