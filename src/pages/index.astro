---
import Default from "../layouts/Default.astro";
import MountainSeparator from "../components/MountainSeparator.astro";
import FAQItem from "../components/FAQItem.astro";
import ContactForm from "../components/ContactForm.astro";
import Footer from "../components/Footer.astro";
import { getEntry, getCollection } from 'astro:content';

const homepage = await getEntry('homepage', 'content');
const { hero, lead, nextRide, values, beer, quote, contact, buttons, video, seo } = homepage.data;

const faqItems = (await getCollection('faq')).sort((a, b) => a.data.order - b.data.order);
const gallery = await getEntry('gallery', 'images');

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SportsClub",
  "name": "Mellowbikers",
  "description": seo.description,
  "url": "https://mellowbikers.nl",
  "logo": "https://mellowbikers.nl/assets/mellowbikers-logo-2023.svg",
  "sameAs": [
    "https://www.facebook.com/mellowbikersnl",
    "https://www.instagram.com/mellowbikers/"
  ],
  "areaServed": "Bergen op Zoom, Brabantse Wal",
  "sport": "Mountain Biking"
};
---
<Default title={seo.title} description={seo.description} jsonLd={jsonLd}>

  <!-- HERO -->
  <section class="hero-mobile-bg relative w-full min-h-[90vh] bg-mellow-dark bg-cover bg-center md:bg-fixed flex flex-col justify-between pt-32 pb-8"
           style={`background-image: url('${hero.backgroundImage}'); background-position: 50% 50%;`}>
    <MountainSeparator position="bottom" color="mellow-dark" />
    <div class="relative z-10 w-full text-center px-4">
      <h1 class="text-6xl md:text-8xl font-black text-white mb-16 text-shadow-lg tracking-tighter">
        {hero.title.split('\n').map((line, i) => i > 0 ? <><br/>{line}</> : line)}
      </h1>
    </div>
    <div class="relative z-10 w-full text-center px-4">
      <h2 class="text-3xl md:text-4xl text-white mb-16 text-shadow-lg">
        {hero.subtitle}
      </h2>
    </div>
  </section>

  <!-- Lead Text Section -->
  <section class="relative w-full bg-mellow-dark py-12 md:py-16 px-4">
    <MountainSeparator position="top" color="mellow-dark" />
    <div class="relative z-10 max-w-7xl mx-auto grid md:grid-cols-2 gap-8 items-center">
      <div class="flex items-center justify-center md:order-2">
        <h4 class="text-7xl md:text-9xl font-black text-mellow-white">{lead.greeting}</h4>
      </div>
      <div class="md:order-1">
        <h3 class="text-2xl md:text-3xl font-bold text-mellow-groen mb-4 leading-tight">
          {lead.title}
        </h3>
        <p class="text-xl md:text-2xl text-mellow-white leading-relaxed" set:html={lead.body} />
      </div>
    </div>
  </section>

  <!-- Buttons Section -->
  <section class="w-full bg-mellow-dark pb-8 px-4">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-4">
      <div class="flex justify-center md:justify-start">
        <a href={buttons.spotlightLink} class="text-3xl w-full md:w-auto text-center px-6 py-3 rounded-lg text-mellow-groen hover:text-mellow-groen/80 font-medium transition-colors">
          {buttons.spotlightText}
        </a>
      </div>
      <div class="flex flex-col gap-4 justify-center">
        <a href={buttons.contactLink} class="w-full text-center px-6 py-3 rounded-lg bg-mellow-blue hover:bg-mellow-red text-mellow-white text-xl font-medium transition-colors border-0">
          {buttons.contactText}
        </a>
        <a href={buttons.memberLink} class="w-full text-center px-6 py-3 rounded-lg border-2 border-mellow-white hover:border-mellow-groen text-xl text-mellow-white hover:text-mellow-groen font-medium transition-colors">
          {buttons.memberText}
        </a>
      </div>
    </div>
  </section>

  <!-- Next Event Section -->
  <section class="w-full bg-mellow-dark py-12 md:py-16 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="border-2 border-mellow-red rounded-lg p-6 md:p-8">
        <div class="grid md:grid-cols-[2fr_1fr] gap-6 items-center">
          <div>
            <h3 class="text-2xl md:text-3xl font-bold text-mellow-groen mb-4 leading-tight">
              {nextRide.title}
            </h3>
            <p class="text-xl md:text-2xl text-mellow-white mb-4 leading-relaxed" set:html={nextRide.body} />
            <a href="#contact" class="inline-block px-6 py-3 rounded-lg bg-mellow-blue hover:bg-mellow-blue/80 text-xl text-mellow-white font-medium transition-colors border-2 border-mellow-blue hover:border-mellow-blue/50">
              {nextRide.ctaText}
            </a>
          </div>
          <div class="flex items-center justify-center">
            <img src={nextRide.image} alt="Mellowbikers group" class="rounded-lg w-full h-auto object-cover aspect-square" style="object-position: 35% 75%;" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Video Banner Section -->
  <section class="relative w-screen h-[300px] md:h-[540px] left-1/2 -translate-x-1/2 bg-mellow-dark flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 w-full h-full">
      <iframe
        src={video.src}
        style="width: 100%; border: none; aspect-ratio: 128/61;"
        allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture;"
        allowfullscreen
        title={video.title}
      ></iframe>
    </div>
  </section>

  <!-- Motto Section -->
  <section class="w-full bg-mellow-red py-12 md:py-16 px-4">
    <div class="max-w-7xl mx-auto grid md:grid-cols-3 gap-6">
      {values.map((value) => (
        <div class="bg-mellow-dark rounded-lg p-6 text-center">
          <h4 class="text-2xl font-bold text-mellow-groen mb-4">{value.title}</h4>
          <p class="text-xl text-mellow-white" set:html={value.body} />
        </div>
      ))}
    </div>
  </section>

  <!-- Beer Banner Section -->
  <section class="w-full bg-mellow-dark py-12 md:py-20 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="rounded-lg p-6 md:p-8">
        <div class="grid md:grid-cols-2 gap-6 items-center">
          <div>
            <h3 class="text-2xl md:text-3xl font-bold text-mellow-groen mb-4 leading-tight">
              {beer.title}
            </h3>
            <p class="text-xl md:text-2xl text-mellow-white mb-4 leading-relaxed">
              {beer.body}
            </p>
            <a href={beer.ctaLink} class="inline-block px-6 py-3 rounded-lg bg-mellow-blue hover:bg-mellow-red text-mellow-white font-medium transition-colors border-0">
              {beer.ctaText}
            </a>
          </div>
          <div class="flex items-center justify-center">
            <img src={beer.image} alt="Let's Ride beer" class="rounded-lg size-auto" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote Section -->
  <section class="w-full bg-mellow-white py-12 md:py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-4xl text-mellow-dark italic">
        "{quote.text}"<br />– {quote.author}
      </p>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="w-full bg-mellow-dark py-12 md:py-16 px-4">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-8 items-start">
      <div>
        <img src="/assets/uploads/20220625_181330_sez7vq34.jpg" alt="Mountainbiken op de Brabantse Wal" class="rounded-lg size-auto" />
      </div>
      <div>
        <h3 class="text-2xl text-mellow-groen font-bold mb-6">Vragen? Check dit:</h3>
        {faqItems.map((item) => (
          <FAQItem question={item.data.question}>
            <Fragment set:html={item.data.answer} />
          </FAQItem>
        ))}
      </div>
    </div>
  </section>

  <!-- Image Carousel Section -->
  <section class="w-full bg-mellow-dark py-12 px-0">
    <div class="overflow-x-auto">
      <div class="flex gap-4 px-4 min-w-max">
        {gallery.data.images.map((img) => (
          <img src={img.src} alt={img.alt} class="w-64 h-64 object-cover rounded aspect-square" loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="w-full bg-mellow-dark py-12 px-4" id="socials">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-8">
      <div>
        <h3 class="text-2xl text-mellow-groen font-bold mb-4">{contact.title}</h3>
        <p class="text-xl text-mellow-white mb-6">
          {contact.body}
        </p>
        <div class="flex gap-4 text-3xl">
          <a href="https://www.facebook.com/mellowbikersnl" target="_blank" rel="noopener noreferrer" class="text-mellow-groen hover:text-mellow-groen/80 transition-colors" aria-label="Facebook">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/mellowbikers/" target="_blank" rel="noopener noreferrer" class="text-mellow-groen hover:text-mellow-groen/80 transition-colors" aria-label="Instagram">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>
      <ContactForm />
    </div>
  </section>

  <!-- Bottom Hero / Footer -->
  <Footer
    backgroundImage="/assets/uploads/mb-hero-2.jpg"
    backgroundPosition="50% 50%"
  />

</Default>
