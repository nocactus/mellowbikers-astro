---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
  jsonLd?: Record<string, any>;
}

const {
  title,
  description = "Dé mountainbike vereniging van de Brabantse Wal",
  ogImage = "/assets/uploads/mb-hero-1-c20-2048.jpg",
  ogType = "website",
  canonicalUrl,
  noIndex = false,
  jsonLd,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://mellowbikers.nl";

const pageTitle = title.includes("Mellowbikers") ? title : `${title} | Mellowbikers`;

const canonical = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`;

const ogImageUrl = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
---

<title>{pageTitle}</title>
<meta name="description" content={description} />

{noIndex && <meta name="robots" content="noindex, nofollow" />}

<link rel="canonical" href={canonical} />

<!-- Open Graph -->
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content="nl_NL" />
<meta property="og:site_name" content="Mellowbikers" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}
